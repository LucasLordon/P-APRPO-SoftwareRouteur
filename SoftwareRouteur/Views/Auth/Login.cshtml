@{
    ViewData["Title"] = "Connexion";
    Layout = null; // Pas de layout, page standalone
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>SafeHome — Connexion</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <style>
        :root {
            --sh-gray-50: #f9fafb;
            --sh-gray-100: #f3f4f6;
            --sh-gray-200: #e5e7eb;
            --sh-gray-300: #d1d5db;
            --sh-gray-400: #9ca3af;
            --sh-gray-500: #6b7280;
            --sh-gray-700: #374151;
            --sh-gray-900: #111827;
            --sh-red-50: #fef2f2;
            --sh-red-700: #b91c1c;
        }

        * { box-sizing: border-box; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: var(--sh-gray-50);
            margin: 0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .login-wrapper {
            width: 100%;
            max-width: 440px;
            padding: 0 1.5rem;
        }

        /* ── Branding ── */
        .login-brand {
            text-align: center;
            margin-bottom: 2.5rem;
        }

        .login-brand-icon {
            width: 64px;
            height: 64px;
            border: 2px solid var(--sh-gray-300);
            border-radius: 14px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1rem;
        }

        .login-brand-icon i {
            font-size: 28px;
            color: var(--sh-gray-700);
        }

        .login-brand-title {
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--sh-gray-900);
            letter-spacing: -0.02em;
            margin: 0 0 0.375rem 0;
            font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
        }

        .login-brand-subtitle {
            font-size: 0.9375rem;
            color: var(--sh-gray-400);
            margin: 0;
        }

        /* ── Card ── */
        .login-card {
            background: #fff;
            border: 1px solid var(--sh-gray-200);
            border-radius: 12px;
            padding: 2rem;
        }

        .login-card-title {
            font-size: 1.375rem;
            font-weight: 700;
            color: var(--sh-gray-900);
            margin: 0 0 1.5rem 0;
        }

        /* ── Form ── */
        .login-form-group {
            margin-bottom: 1.25rem;
        }

        .login-label {
            display: block;
            font-size: 0.8125rem;
            font-weight: 600;
            color: var(--sh-gray-700);
            margin-bottom: 0.375rem;
        }

        .login-input {
            width: 100%;
            padding: 0.625rem 0.875rem;
            border: 1px solid var(--sh-gray-200);
            border-radius: 8px;
            font-size: 0.9375rem;
            color: var(--sh-gray-900);
            background: var(--sh-gray-50);
            transition: border-color 0.15s, box-shadow 0.15s;
        }

        .login-input:focus {
            outline: none;
            border-color: var(--sh-gray-400);
            box-shadow: 0 0 0 3px rgba(156, 163, 175, 0.15);
            background: #fff;
        }

        .login-input::placeholder {
            color: var(--sh-gray-400);
        }

        .login-btn {
            width: 100%;
            padding: 0.75rem;
            background: var(--sh-gray-900);
            color: #fff;
            border: none;
            border-radius: 8px;
            font-size: 0.9375rem;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.15s;
            margin-top: 0.5rem;
        }

        .login-btn:hover {
            background: var(--sh-gray-700);
        }

        /* ── Error ── */
        .login-error {
            background: var(--sh-red-50);
            color: var(--sh-red-700);
            border: 1px solid #fecaca;
            padding: 0.625rem 0.875rem;
            border-radius: 8px;
            font-size: 0.8125rem;
            margin-bottom: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        /* ── Footer ── */
        .login-footer {
            text-align: center;
            margin-top: 2rem;
            font-size: 0.75rem;
            color: var(--sh-gray-400);
        }
    </style>
</head>
<body>
<div class="login-wrapper">
    <!-- Branding -->
    <div class="login-brand">
        <div class="login-brand-icon">
            <i class="bi bi-shield-check"></i>
        </div>
        <h1 class="login-brand-title">SafeHome</h1>
        <p class="login-brand-subtitle">Administration du routeur familial</p>
    </div>

    <!-- Login card -->
    <div class="login-card">
        <h2 class="login-card-title">Connexion</h2>

        @if (ViewBag.Error != null)
        {
            <div class="login-error">
                <i class="bi bi-exclamation-triangle-fill"></i>
                @ViewBag.Error
            </div>
        }

        <form method="post" asp-action="Login">
            <div class="login-form-group">
                <label class="login-label">Nom d'utilisateur</label>
                <input type="text" name="username" class="login-input"
                       placeholder="admin" required autofocus/>
            </div>
            <div class="login-form-group">
                <label class="login-label">Mot de passe</label>
                <input type="password" name="password" class="login-input"
                       placeholder="••••••" required/>
            </div>
            <button type="submit" class="login-btn">Se connecter</button>
        </form>
    </div>

    <div class="login-footer">
        &copy; 2026 SafeHome — Software Router TPI
    </div>
</div>
</body>
</html>
