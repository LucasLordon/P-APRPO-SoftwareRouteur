<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - SafeHome Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/SoftwareRouteur.styles.css" asp-append-version="true"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <style>
        * { box-sizing: border-box; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: var(--sh-gray-50);
            color: var(--sh-gray-900);
            margin: 0;
        }

        /* ── Header ── */
        .sh-header {
            background: #fff;
            border-bottom: 1px solid var(--sh-gray-200);
            padding: 0 2rem;
        }

        .sh-header-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 64px;
        }

        .sh-brand {
            display: flex;
            align-items: center;
            gap: 0.625rem;
            text-decoration: none;
            color: var(--sh-dark);
        }

        .sh-brand-icon {
            width: 32px;
            height: 32px;
            border: 2px solid var(--sh-gray-300);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .sh-brand-icon i { font-size: 16px; color: var(--sh-gray-500); }

        .sh-brand-text {
            font-size: 1.125rem;
            font-weight: 700;
            letter-spacing: -0.01em;
            font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
        }

        .sh-header-right {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .sh-user {
            font-size: 0.875rem;
            color: var(--sh-gray-500);
        }

        .sh-logout-btn {
            display: flex;
            align-items: center;
            gap: 0.375rem;
            padding: 0.375rem 0.875rem;
            border: 1px solid var(--sh-gray-200);
            border-radius: 6px;
            background: #fff;
            color: var(--sh-gray-700);
            font-size: 0.8125rem;
            font-weight: 500;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.15s;
        }

        .sh-logout-btn:hover {
            background: var(--sh-gray-50);
            color: var(--sh-gray-900);
        }

        /* ── Tabs ── */
        .sh-tabs {
            display: flex;
            gap: 0;
            margin-top: -1px;
        }

        .sh-tab {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.75rem 1.25rem;
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--sh-gray-500);
            text-decoration: none;
            border-bottom: 2px solid transparent;
            transition: all 0.15s;
        }

        .sh-tab:hover {
            color: var(--sh-gray-700);
        }

        .sh-tab.active {
            color: var(--sh-gray-900);
            border-bottom-color: var(--sh-gray-900);
        }

        .sh-tab i { font-size: 1rem; }

        /* ── Main content ── */
        .sh-main {
            max-width: 1400px;
            margin: 0 auto;
            padding: 2rem;
        }

        /* ── Alerts ── */
        .sh-alert {
            padding: 0.75rem 1rem;
            border-radius: 8px;
            font-size: 0.875rem;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .sh-alert-success {
            background: var(--sh-green-50);
            color: var(--sh-green-700);
            border: 1px solid #bbf7d0;
        }

        .sh-alert-error {
            background: var(--sh-red-50);
            color: var(--sh-red-700);
            border: 1px solid #fecaca;
        }

        /* ── Footer ── */
        .sh-footer {
            text-align: center;
            padding: 2rem;
            font-size: 0.75rem;
            color: var(--sh-gray-400);
        }
    </style>
</head>
<body>
<header class="sh-header">
    <div class="sh-header-top">
        <a class="sh-brand" asp-controller="Home" asp-action="Index">
            <span class="sh-brand-icon"><i class="bi bi-shield-check"></i></span>
            <span class="sh-brand-text">SafeHome Admin</span>
        </a>
        <div class="sh-header-right">
            <span class="sh-user">User: @User.Identity?.Name</span>
            <form method="post" asp-controller="Auth" asp-action="Logout" style="display:inline">
                <button type="submit" class="sh-logout-btn">
                    <i class="bi bi-box-arrow-right"></i> Logout
                </button>
            </form>
        </div>
    </div>
    <nav class="sh-tabs">
        <a class="sh-tab @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
           asp-controller="Home" asp-action="Index">
            <i class="bi bi-house"></i> Dashboard
        </a>
        <a class="sh-tab @(ViewContext.RouteData.Values["controller"]?.ToString() == "Client" ? "active" : "")"
           asp-controller="Client" asp-action="Index">
            <i class="bi bi-people"></i> Edit Users
        </a>
        <a class="sh-tab @(ViewContext.RouteData.Values["controller"]?.ToString() == "Firewall" ? "active" : "")"
           asp-controller="Firewall" asp-action="Index">
            <i class="bi bi-shield-lock"></i> Edit Rules
        </a>
    </nav>
</header>

<div class="sh-main">
    @if (TempData["Success"] != null)
    {
        <div class="sh-alert sh-alert-success">
            <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="sh-alert sh-alert-error">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
        </div>
    }
    <main>
        @RenderBody()
    </main>
</div>

<footer class="sh-footer">
    &copy; 2026 SafeHome — Software Router TPI
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
